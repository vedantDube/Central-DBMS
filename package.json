{
  "name": "cdbms",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "ingest": "tsx src/index.ts",
    "returnprime:fetch": "tsx src/returnprime/fetch-returns.ts",
    "amazon:gst-mtr-browser": "tsx src/amazon/gst-mtr-browser.ts",
    "amazon:gst-monthly-browser": "tsx src/amazon/gst-monthly-browser.ts",
    "shiprocket:fetch-orders": "tsx src/shiprocket/fetch-orders.ts",
    "easyecom:fetch-inventory": "tsx src/easyecom/fetch-inventory.ts",
    "shopify:fetch-orders": "tsx src/shopify/fetch-orders.ts",
    "shopify:fetch-returns": "tsx src/shopify/fetch-returns.ts",
    "shopify:fetch-inventory": "tsx src/shopify/fetch-inventory.ts",
    "browser:save-profile": "tsx src/amazon/save-profile.ts",
    "prisma:generate": "prisma generate && prisma generate --schema=prisma/schema_amazon.prisma",
    "prisma:push": "prisma db push && prisma db push --schema=prisma/schema_amazon.prisma",
    "db:clear": "tsx scratch/clear_databases.ts",
    "download-report": "tsx src/reports/download-report.ts",
    "request-amazon-reports": "tsx src/reports/request_amazon_reports.ts",
    "ingest:all": "tsx src/run-all.ts",
    "scheduler": "tsx src/scheduler.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "@supabase/supabase-js": "^2.56.0",
    "amazon-sp-api": "^1.2.1",
    "axios": "^1.16.1",
    "csv-parse": "^5.4.0",
    "dotenv": "^17.2.0",
    "playwright": "^1.56.0",
    "unzipper": "^0.10.11",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.17.0",
    "prisma": "^6.14.0",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  }
}
