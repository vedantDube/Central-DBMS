  quantityreimbursedtotal     String?
  originalreimbursementid     String?
  originalreimbursementtype   String?

  @@index([reportKey, createdAt])
}

model AmazonReturnsB2bRow {
  id         String   @id @default(cuid())
  reportKey  String
  createdAt  DateTime @default(now())

  // TSV Columns
  requestdate        String?
  orderid            String?
  shipmentdate       String?
  sku                String?
  fnsku              String?
  disposition        String?
  shippedquantity    String?
  carrier            String?
