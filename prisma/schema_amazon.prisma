model AmazonSalesAndTrafficRow {
  id         String   @id @default(cuid())
  reportKey  String
  createdAt  DateTime @default(now())

  // Extracted JSON Columns
  type                         String?  // "date" or "asin"
  date                         String?
  parentAsin                   String?
  orderedProductSalesAmount    String?
  orderedProductSalesCurrency  String?
  unitsOrdered                 String?
  pageViews                    String?
  sessions                     String?

  @@index([reportKey, createdAt])
}

