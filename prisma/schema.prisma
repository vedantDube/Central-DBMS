generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ReportArtifact {
  id          String   @id @default(cuid())
  reportKey   String
  reportLabel String
  storagePath String
  fileName    String
  contentType String
  source      String
  rawContent  String
  sha256      String
  createdAt   DateTime @default(now())

  @@index([reportKey, createdAt])
  @@index([storagePath, createdAt])
}

model ReturnPrimeReturn {
  id                   String   @id @default(cuid())
  returnPrimeId        String?  @unique
  requestNumber         String?
  requestType           String?
  status                String?
  channel               Int?
  orderId               String?
  orderName             String?
  orderCreatedAt        DateTime?
  fulfillmentId         String?
  deliveryStatus        String?
  deliveryDate          DateTime?
  customerEmail         String?
  postalCode            String?
  receivedStatus        Boolean  @default(false)
  inspectedStatus       Boolean  @default(false)
  rejectedStatus        Boolean  @default(false)
  archivedStatus        Boolean  @default(false)
  refundStatus          String?
  eligibleRefundStatus  Boolean  @default(false)
  refundedAmount        Decimal  @default(0)
  originalProductId     String?
  sku                   String?
  tracking              String?
  quantity              Int?
  actualAmount          Decimal?
  imageSrc              String?
  rawJson               Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([requestNumber])
  @@index([status, channel])
  @@index([createdAt])
}

model ShiprocketOrder {
  id                String   @id @default(cuid())
  shiprocketOrderId String?  @unique
  channelId         String?
  channelOrderId    String?
  status            String?
  awb               String?
  productId         String?
  productName       String?
  price             Decimal?
  shipmentId        String?
  rtoAwb            String?
  returnAwb         String?
  etd               DateTime?
  rtoInitiatedAt    DateTime?
  orderItemSku      String?
  packageId         String?
  rawPayload        Json?
  rawContent        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([channelOrderId])
  @@index([awb])
  @@index([status])
  @@index([createdAt])
}

model EasyEcomInventory {
  id              String   @id @default(cuid())
  date            String   // Snapshot Date: yyyy-MM-dd
  sku             String
  name            String?
  modelNo         String?
  color           String?
  size            String?
  brand           String?
  quantity        Int?
  inventoryStatus String?

  rawJson         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([date, sku])
  @@index([date])
  @@index([sku])
}

model ShopifyOrder {
