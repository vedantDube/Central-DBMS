generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ReportArtifact {
  id          String   @id @default(cuid())
  reportKey   String
  reportLabel String
  storagePath String
  fileName    String
  contentType String
  source      String
  rawContent  String   @db.Text
  sha256      String
  createdAt   DateTime @default(now())

  @@index([reportKey, createdAt])
  @@index([storagePath, createdAt])
}

model ReturnPrimeReturn {
  id                   String   @id @default(cuid())
  returnPrimeId        String?  @unique
  requestNumber         String?
  requestType           String?
  status                String?
  channel               Int?
  orderId               String?
  orderName             String?
  orderCreatedAt        DateTime?
  fulfillmentId         String?
  deliveryStatus        String?
  deliveryDate          DateTime?
  customerEmail         String?
  postalCode            String?
  receivedStatus        Boolean  @default(false)
  inspectedStatus       Boolean  @default(false)
  rejectedStatus        Boolean  @default(false)
  archivedStatus        Boolean  @default(false)
  refundStatus          String?
  eligibleRefundStatus  Boolean  @default(false)
  refundedAmount        Decimal  @default(0)
  originalProductId     String?
  sku                   String?
  tracking              String?
  quantity              Int?
  actualAmount          Decimal?
  imageSrc              String?
  rawJson               Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([requestNumber])
  @@index([status, channel])
  @@index([createdAt])
}

model ShiprocketOrder {
  id                String   @id @default(cuid())
  shiprocketOrderId String?  @unique
  channelId         String?
  channelOrderId    String?
  status            String?
  awb               String?
  productId         String?
  productName       String?
  price             Decimal?
  shipmentId        String?
  rtoAwb            String?
  returnAwb         String?
  etd               DateTime?
  rtoInitiatedAt    DateTime?
  orderItemSku      String?
  packageId         String?
  rawPayload        Json?
  rawContent        String   @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([channelOrderId])
  @@index([awb])
  @@index([status])
  @@index([createdAt])
}

model EasyEcomInventory {
  id              String   @id @default(cuid())
  date            String   // Snapshot Date: yyyy-MM-dd
  sku             String
  name            String?
  modelNo         String?
  color           String?
  size            String?
  brand           String?
  quantity        Int?
  inventoryStatus String?

  rawJson         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([date, sku])
  @@index([date])
  @@index([sku])
}

model ShopifyOrder {
  id                                    String                 @id // Admin GraphQL API ID (e.g. gid://shopify/Order/xxx)
  shopifyOrderId                        String                 @unique // REST Order ID (numeric string)
  appId                                 String?
  browserIp                             String?
  buyerAcceptsMarketing                 Boolean?
  cancelReason                          String?
  cancelledAt                           DateTime?
  cartToken                             String?
  checkoutId                            String?
  checkoutToken                         String?
  clientDetails                         Json?
  closedAt                              DateTime?
  company                               Json?
  confirmationNumber                    String?
  confirmed                             Boolean?
  contactEmail                          String?
  createdAt                             DateTime?
  currency                              String?
  currentSubtotalPrice                  Decimal?               @db.Decimal(12, 4)
  currentSubtotalPriceSet               Json?
  currentTotalAdditionalFeesSet         Json?
  currentTotalDiscounts                 Decimal?               @db.Decimal(12, 4)
  currentTotalDiscountsSet              Json?
  currentTotalDutiesSet                 Json?
  currentTotalPrice                     Decimal?               @db.Decimal(12, 4)
  currentTotalPriceSet                  Json?
  currentTotalTax                       Decimal?               @db.Decimal(12, 4)
  currentTotalTaxSet                    Json?
  customerLocale                        String?
  deviceId                              String?
  discountCodes                         Json?
  dutiesIncluded                        Boolean?
  email                                 String?
  estimatedTaxes                        Boolean?
  financialStatus                       String?
  fulfillmentStatus                     String?
  landingSite                           String?
  landingSiteRef                        String?
  locationId                            String?
  merchantBusinessEntityId              String?
  merchantOfRecordAppId                 String?
  name                                  String?
  note                                  String?
  noteAttributes                        Json?
  number                                Int?
  orderNumber                           Int?
  orderStatusUrl                        String?
  originalTotalAdditionalFeesSet        Json?
  originalTotalDutiesSet                Json?
  paymentGatewayNames                   Json?
  phone                                 String?
  poNumber                              String?
  presentmentCurrency                   String?
  processedAt                           DateTime?
  reference                             String?
  referringSite                         String?
  sourceIdentifier                      String?
  sourceName                            String?
  sourceUrl                             String?
  subtotalPrice                         Decimal?               @db.Decimal(12, 4)
  subtotalPriceSet                      Json?
  tags                                  String?
  taxExempt                             Boolean?
  taxLines                              Json?
  taxesIncluded                         Boolean?
  test                                  Boolean?
  token                                 String?
  totalCashRoundingPaymentAdjustmentSet Json?
  totalCashRoundingRefundAdjustmentSet  Json?
  totalDiscounts                        Decimal?               @db.Decimal(12, 4)
  totalDiscountsSet                     Json?
  totalLineItemsPrice                   Decimal?               @db.Decimal(12, 4)
  totalLineItemsPriceSet                Json?
  totalOutstanding                      Decimal?               @db.Decimal(12, 4)
  totalPrice                            Decimal?               @db.Decimal(12, 4)
  totalPriceSet                         Json?
  totalShippingPriceSet                 Json?
  totalTax                              Decimal?               @db.Decimal(12, 4)
  totalTaxSet                           Json?
  totalTipReceived                      Decimal?               @db.Decimal(12, 4)
  totalWeight                           Int?
  updatedAt                             DateTime?
  userId                                String?
  billingAddress                        Json?
  customer                              Json?
  discountApplications                  Json?
  fulfillments                          Json?
  paymentTerms                          Json?
  refunds                               Json?
  shippingAddress                       Json?
  shippingLines                         Json?
  rawJson                               Json?
  dbCreatedAt                           DateTime               @default(now())
  dbUpdatedAt                           DateTime               @updatedAt
  lineItems                             ShopifyOrderLineItem[]

  @@index([orderNumber])
  @@index([financialStatus])
  @@index([fulfillmentStatus])
  @@index([createdAt])
}

model ShopifyOrderLineItem {
  id                         String       @id // Admin GraphQL API ID (e.g. gid://shopify/LineItem/xxx)
  shopifyLineItemId          String       @unique // REST Line Item ID (numeric string)
  orderId                    String
  attributedStaffs           Json?
  currentQuantity            Int?
  fulfillableQuantity        Int?
  fulfillmentService         String?
  fulfillmentStatus          String?
  giftCard                   Boolean?
  grams                      Int?
  name                       String?
  price                      Decimal?     @db.Decimal(12, 4)
  priceSet                   Json?
  productExists              Boolean?
  productId                  String?
  properties                 Json?
  quantity                   Int?
  requiresShipping           Boolean?
  sku                        String?
  taxable                    Boolean?
  title                      String?
  totalDiscount              Decimal?     @db.Decimal(12, 4)
  totalDiscountSet           Json?
  variantId                  String?
  variantInventoryManagement String?
  variantTitle               String?
  vendor                     String?
  taxLines                   Json?
  duties                     Json?
  discountAllocations        Json?
  order                      ShopifyOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([sku])
  @@index([productId])
  @@index([variantId])
}

model ShopifyReturn {
  id                        String                  @id // GraphQL ID (e.g. gid://shopify/Return/xxx)
  name                      String?
  status                    String?
  createdAt                 DateTime?
  closedAt                  DateTime?
  requestApprovedAt         DateTime?
  totalQuantity             Int?
  orderId                   String?
  declineReason             String?
  declineNote               String?
  refunds                   Json?
  returnShippingFees        Json?
  reverseFulfillmentOrders  Json?
  suggestedFinancialOutcome Json?
  rawJson                   Json?
  dbCreatedAt               DateTime                @default(now())
  dbUpdatedAt               DateTime                @updatedAt
  returnLineItems           ShopifyReturnLineItem[]

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model ShopifyReturnLineItem {
  id                              String        @id // GraphQL ID (e.g. gid://shopify/ReturnLineItem/xxx)
  returnId                        String
  customerNote                    String?
  fulfillmentLineItem             Json?
  processableQuantity             Int?
  processedQuantity               Int?
  quantity                        Int?
  refundableQuantity              Int?
  refundedQuantity                Int?
  restockingFee                   Json?
  returnReason                    String?
  returnReasonNote                String?
  totalWeight                     Json?
  unprocessedQuantity             Int?
  withCodeDiscountedTotalPriceSet Json?
  return                          ShopifyReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
}

model ShopifyInventoryItem {
  id                           String                  @id // GraphQL ID (e.g. gid://shopify/InventoryItem/xxx)
  legacyResourceId             String?
  sku                          String?
  unitCost                     Decimal?                @db.Decimal(12, 4)
  tracked                      Boolean?
  requiresShipping             Boolean?
  createdAt                    DateTime?
  updatedAt                    DateTime?
  variantId                    String?
  countryCodeOfOrigin          String?
  countryHarmonizedSystemCodes Json?
  duplicateSkuCount            Int?
  harmonizedSystemCode         String?
  inventoryHistoryUrl          String?
  locationsCount               Int?
  measurement                  Json?
  provinceCodeOfOrigin         String?
  trackedEditable              Json?
  dbCreatedAt                  DateTime                @default(now())
  dbUpdatedAt                  DateTime                @updatedAt
  levels                       ShopifyInventoryLevel[]

  @@index([sku])
}

model ShopifyInventoryLevel {
  id                String               @id @default(cuid()) // Change from GraphQL ID to auto-generated CUID to allow daily duplicates
  shopifyLevelId    String // Store the GraphQL ID here
  inventoryItemId   String
  date              String // Snapshot Date: yyyy-MM-dd
  snapshotType      String // "Opening" or "Closing"
  createdAt         DateTime?
  updatedAt         DateTime?
  locationId        String?
  locationName      String?
  canDeactivate     Boolean?
  deactivationAlert String?
  availableQty      Int?
  onHandQty         Int?
  committedQty      Int?
  reservedQty       Int?
  rawJson           Json?
  item              ShopifyInventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([date, snapshotType, inventoryItemId, locationId]) // Allow one log per day/snapshot/location
  @@index([date, snapshotType])
  @@index([inventoryItemId])
  @@index([locationId])
}

model EasyEcomProductMaster {
  id                             String   @id @default(cuid())
  createdAt                      DateTime @default(now())
  
  cp_id                          Int      @unique
  product_id                     Int
  sku                            String
  product_name                   String?
  description                    String?
  active                         String?
  created_at                     String?
  updated_at                     String?
  inventory                      Int?
  product_type                   String?
  brand                          String?
  colour                         String?
  category_id                    Int?
  brand_id                       Int?
  accounting_sku                 String?
  accounting_unit                String?
  category_name                  String?
  expiry_type                    String?
  category_shelf_life            Int?
  category_shelf_life_percentage Float?
  company_name                   String?
  c_id                           Int?
  height                         String?
  length                         String?
  width                          String?
  weight                         String?
  cost                           Float?
  mrp                            Float?
  size                           String?
  cp_sub_products_count          Int?
  model_no                       String?
  EANUPC                         String?
  hsn_code                       String?
  product_image_url              String?
  cp_inventory                   Int?
  tax_rule_name                  String?
  tax_rate                       Float?
  vendor_code                    String?
}

model EasyEcomPurchaseOrder {
  id                      String   @id @default(cuid())
  createdAt               DateTime @default(now())
  
  po_id                   Int      @unique
  total_po_value          String?
  po_number               Int?
  po_ref_num              String?
  po_status_id            Int?
  po_created_date         String?
  po_updated_date         String?
  po_created_warehouse    String?
  po_created_location_key String?
  vendor_name             String?
  vendor_c_id             Int?
  vendor_code             String?
  vendor_location_key     String?
  
  items                   Json     // Stores array of po_items
}

model EasyEcomProductionOrder {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())
  
  invoice_id            Int      @unique
  order_id              Int
  reference_code        String?
  company_name          String?
  location_key          String?
  warehouseId           Int?
  import_warehouse_name String?
  order_type            String?
  order_type_key        String?
  marketplace           String?
  order_date            String?
  invoice_date          String?
  last_update_date      String?
  invoice_number        String?
  order_status          String?
  order_status_id       Int?
  shipping_status       String?
  payment_mode          String?
  customer_name         String?
  contact_num           String?
  city                  String?
  pin_code              String?
  state                 String?
  country               String?
  total_amount          Float?
  total_tax             Float?
  total_discount        Float?
  collectable_amount    Float?
  
  suborders             Json     // Stores array of suborders
}

